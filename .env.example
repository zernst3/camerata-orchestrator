# Camerata local config template. Copy to `.env` (gitignored) and fill in.
# The app auto-loads `.env` at startup (run from the repo dir).

# GitHub PAT (classic, full scope is fine) — enables scan / adopt / arm / emit /
# reconcile / tickets. Without it the app runs on the built-in native tracker.
CAMERATA_GITHUB_TOKEN=

# Optional: the default repo the background poller watches for PO comments.
CAMERATA_GITHUB_REPO=

# Optional: GitHub Projects v2 board (for `cargo run -p camerata -- projects-live`).
# CAMERATA_GITHUB_PROJECT_OWNER=
# CAMERATA_GITHUB_PROJECT_NUMBER=
# CAMERATA_GITHUB_PROJECT_KIND=user

# Optional: run a REAL claude -p fleet (otherwise runs are scripted/token-free).
# CAMERATA_LIVE_BUILD=1

# Optional poller cadences (defaults shown).
# CAMERATA_POLL_TRACKER_SECS=45
# CAMERATA_POLL_DEPLOY_SECS=5
# CAMERATA_UI_NOTIFY_SECS=5
