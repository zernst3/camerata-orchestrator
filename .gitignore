# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo

# Camerata runtime (per-task isolated checkouts + coordination artifacts)
.claude/worktrees/
.claude/coordination/
.camerata/cache/

# Secrets and local config (NEVER commit; see TECH_DESIGN section 10)
.env
.env.*
!.env.example
*.local
secrets.*
# `secrets.*` above is meant for actual secret dumps (secrets.json/.yaml/.env-ish
# files), but as an unanchored glob it ALSO matched Rust source modules named
# `secrets.rs` (e.g. `crates/orchestrator/src/secrets.rs`, a real detector/scrubber
# module, not a secret). That silently dropped the file from a real commit
# (fa37fb0) — `git add` skipped it with no error, the commit landed missing the
# file, and `cargo check` broke for the next checkout. Un-ignore Rust source
# specifically so this class of silent data loss can't recur.
!**/secrets.rs

# Persistence store (local SQLite / flat-file Story spine)
*.sqlite
*.sqlite-journal
*.db
data/

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Rust
/target

# audio experiment assets
docs/plans/*.mp3
